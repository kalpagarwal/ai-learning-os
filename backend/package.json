{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "node --import tsx prisma/seed.ts",
    "samples:create-pdfs": "node --import tsx scripts/createSamplePdfs.ts",
    "vectors:seed": "node --import tsx scripts/seedSampleVectors.ts"
  },
  "dependencies": {
    "@openai/agents": "^0.0.10",
    "@prisma/client": "^6.7.0",
    "@qdrant/js-client-rest": "^1.13.0",
    "bullmq": "^5.50.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.104.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.8.2",
    "prisma": "^6.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.7.2"
  }
}
