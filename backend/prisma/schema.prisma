generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum TopicStrength {
  WEAK
  MEDIUM
  STRONG
}

model User {
  id              String            @id @default(cuid())
  email           String?           @unique
  createdAt       DateTime          @default(now())
  conversations   Conversation[]
  topics          LearningTopic[]
  roadmaps        LearningRoadmap[]
  quizAttempts    QuizAttempt[]
}

model Conversation {
  id              String            @id @default(cuid())
  title           String?
  userId          String?
  user            User?             @relation(fields: [userId], references: [id])
  createdAt       DateTime          @default(now())
  messages        Message[]
  toolExecutions  ToolExecution[]
  agentExecutions AgentExecution[]
}

model Message {
  id              String            @id @default(cuid())
  conversationId  String
  conversation    Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            MessageRole
  content         String
  agentName       String?
  toolCallsJson   Json?
  retrievalJson   Json?
  createdAt       DateTime          @default(now())
}

model Document {
  id              String            @id @default(cuid())
  title           String
  sourcePath      String
  status          String
  createdAt       DateTime          @default(now())
  chunks          Chunk[]
}

model Chunk {
  id              String            @id @default(cuid())
  documentId      String
  document        Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex      Int
  text            String
  tokenCount      Int
  metadataJson    Json?
  createdAt       DateTime          @default(now())
}

model LearningTopic {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic           String
  strength        TopicStrength     @default(WEAK)
  confidence      Float             @default(0.3)
  lastReviewedAt  DateTime?
  updatedAt       DateTime          @updatedAt

  @@unique([userId, topic])
}

model LearningRoadmap {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  stepsJson       Json
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model QuizAttempt {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic           String
  questionsJson   Json
  answersJson     Json
  score           Int
  total           Int
  createdAt       DateTime          @default(now())
}

model ToolExecution {
  id              String            @id @default(cuid())
  conversationId  String?
  conversation    Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  agentName       String
  toolName        String
  inputJson       Json
  outputJson      Json
  durationMs      Int
  createdAt       DateTime          @default(now())
}

model AgentExecution {
  id              String            @id @default(cuid())
  conversationId  String?
  conversation    Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  agentName       String
  status          String
  stepsJson       Json
  durationMs      Int
  startedAt       DateTime
  endedAt         DateTime
  createdAt       DateTime          @default(now())
}
